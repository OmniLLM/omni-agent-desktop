{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omni Agent Desktop",
  "version": "0.1.0",
  "identifier": "com.omnillm.omni-agent-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Omni Agent Desktop",
        "width": 1280,
        "height": 720,
        "minWidth": 360,
        "minHeight": 56,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "externalBin": ["binaries/agent-core"]
  }
}
